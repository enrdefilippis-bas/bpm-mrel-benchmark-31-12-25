__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env
.env.local

# Data — large files and raw PDFs kept out of git
data/raw/pdfs/**/*.pdf
data/processed/*.parquet
data/db/*.duckdb
data/processed/ingest_log.json

# Exceptions: small processed tables needed at runtime (tracked in git)
!data/processed/banks.parquet
!data/processed/facts.parquet

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp

# Tests
.pytest_cache/
.coverage
htmlcov/

# Dash / Plotly cache
.dash_cache/

# CI venv + scratch / planning files (never tracked)
.venv_ci/
debug_*.py
test_intesa_parser.py
PARSER_PLANNING_BRIEF.txt

# Excel deliverables (generati on-demand, non parte del runtime app)
MREL_CDA_*.xlsx
~$*.xlsx
~$*.docx
*.tmp.xlsx
dashboard_mrel_cda_*.html

# Documenti deck CdA (mantenuti localmente, non nel repo pubblico)
docs/presentazione_*.docx
docs/presentazione_*.pptx
